# Copy to .env and fill DB credentials from DB API Marketplace
DB_CLIENT_ID=
DB_API_KEY=

# Optional overrides
# DB_TIMETABLES_BASE_URL=https://apis.deutschebahn.com/db-api-marketplace/apis/timetables/v1
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/137.0.0.0 Safari/537.36
# DEBUG_MODE=0
# DEBUG_LOG_PATH=/logs/logfile.txt
# WARMUP_ON_START=0
# WARMUP_STATIC_CACHE_ON_START=1
# CONFIG_PATH=/app/config.example.yaml
# FALLBACK_CONFIG_PATH=/app/config.example.yaml
# GTFS static cache (use /tmp by default to avoid small /data volumes)
# GTFS_STATIC_CACHE_PATH=/tmp/nv_free_latest.zip
# GTFS_STATIC_CACHE_MAX_AGE_SECONDS=43200



